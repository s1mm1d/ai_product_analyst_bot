    {
      "parameters": {
        "jsCode": "const MAX_LENGTH = 3800;\nconst text = $('Format Response').item.json.formatted_response;\nconst chatId = $('Format Response').item.json.chat_id;\nconst userId = $('Format Response').item.json.user_id;\nconst timestamp = $('Format Response').item.json.timestamp;\n\nconst chunks = [];\nlet currentChunk = '';\n\n// Split by lines to avoid breaking in the middle of content\nconst lines = text.split('\\n');\n\nfor (const line of lines) {\n  // If adding this line would exceed the limit, save current chunk and start new one\n  if (currentChunk.length + line.length + 1 > MAX_LENGTH && currentChunk.length > 0) {\n    chunks.push(currentChunk);\n    currentChunk = line;\n  } else {\n    currentChunk += (currentChunk ? '\\n' : '') + line;\n  }\n}\n\n// Add the last chunk\nif (currentChunk) {\n  chunks.push(currentChunk);\n}\n\n// Return array of items, one per chunk\nreturn chunks.map((chunk, index) => ({\n  json: {\n    message_text: chunk,\n    chat_id: chatId,\n    user_id: userId,\n    timestamp: timestamp,\n    part: index + 1,\n    total_parts: chunks.length\n  }\n}));"
      },
      "id": "19b9c8ba-48b1-415b-8c3d-0f3297115520",
      "name": "Split Long Message",
